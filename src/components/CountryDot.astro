---
/**
 * 국가 코드별 고유 색 도트.
 * locale-data.ts의 색상 맵과 global.css의 --dot-XX 변수를 동기화해서 유지하세요.
 */
interface Props {
  code: string;
  size?: number; // px
}

const { code, size = 24 } = Astro.props;

// CSS 변수로 색상을 가져오되, 정의되지 않은 국가 코드는 --text-muted로 폴백
const cssVar = `var(--dot-${code.toLowerCase()}, var(--text-muted))`;
const fs = size < 26 ? 9 : size < 32 ? 10 : 12;
---

<div
  class="dot"
  style={`width:${size}px;height:${size}px;background:${cssVar};font-size:${fs}px;`}
  aria-hidden="true"
>
  {code}
</div>
