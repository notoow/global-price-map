---
import Layout from "../components/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import type { GeneratedData } from "../lib/schema.ts";
import { SITE, absoluteUrl, withBase } from "../lib/site.ts";

import data from "../data/generated/services.json";

const { services, ratesAsOf } = data as GeneratedData;

const categories = [
  { id: "ott", label: "OTT / 영상" },
  { id: "ai-agent", label: "AI 에이전트" },
  { id: "productivity", label: "생산성 / 크리에이티브" },
  { id: "music", label: "음악" },
] as const;

const categoryLabelById = new Map(categories.map((category) => [category.id, category.label]));
const serviceGroups = categories
  .map((category) => ({
    ...category,
    services: services.filter((service) => service.category === category.id),
  }))
  .filter((group) => group.services.length > 0);

const serviceItems = services.map((svc, index) => ({
  "@type": "ListItem",
  position: index + 1,
  name: svc.name,
  url: absoluteUrl(`/services/${svc.id}/`),
  description: `${svc.name} ${svc.plan} 국가별 구독 가격 비교`,
}));

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: absoluteUrl("/"),
    inLanguage: SITE.language,
    description: SITE.description,
    potentialAction: {
      "@type": "SearchAction",
      target: `${absoluteUrl("/")}?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "구독 서비스 국가별 가격 비교 목록",
    itemListElement: serviceItems,
  },
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    name: "구독 서비스 국가별 가격 비교 데이터",
    url: absoluteUrl("/"),
    inLanguage: SITE.language,
    dateModified: ratesAsOf,
    description: SITE.description,
    keywords: "구독 서비스 가격 비교, 국가별 구독료, AI 구독 가격, OTT 가격, Adobe Creative Cloud 가격",
    creator: {
      "@type": "Organization",
      name: SITE.name,
      url: absoluteUrl("/"),
    },
  },
];
---

<Layout
  title="구독 서비스 국가별 가격 비교 및 최저가 순위 — 서브링크"
  description="OTT, AI 에이전트, 음악, 생산성 구독 서비스의 국가별 가격을 KRW 기준으로 비교하세요."
  ratesAsOf={ratesAsOf}
  jsonLd={jsonLd}
>
  <section aria-labelledby="hero-title" class="home-hero">
    <h1 id="hero-title">구독 서비스<br />국가별 가격 비교</h1>
    <p>OTT, AI, 음악, 생산성 구독 가격을 KRW 기준으로 비교해요</p>
  </section>

  <div class="search-wrap home-search" role="search">
    <label for="svc-search" class="visually-hidden">서비스 검색</label>
    <svg
      class="search-wrap__icon"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" />
    </svg>
    <input
      id="svc-search"
      type="search"
      class="search-input"
      placeholder="서비스 이름으로 검색 (유튜브, 넷플릭스, 클로드...)"
      autocomplete="off"
      spellcheck="false"
    />
  </div>

  <div class="service-summary">
    <p>전체 <span id="count">{services.length}</span>개 서비스</p>
    <p>섹션별 정렬</p>
  </div>

  <section aria-label="서비스 목록" class="service-sections">
    {serviceGroups.map((group) => (
      <section class="service-section" data-category-section>
        <div class="service-section__header">
          <h2>{group.label}</h2>
          <span>{group.services.length}개</span>
        </div>
        <ul class="service-grid" style="list-style:none;">
          {group.services.map((svc) => (
            <li
              data-search={`${svc.name} ${svc.id} ${svc.plan} ${categoryLabelById.get(svc.category) ?? ""}`.toLowerCase()}
              data-empty="false"
            >
              <ServiceCard service={svc} href={withBase(`/services/${svc.id}/`)} />
            </li>
          ))}
        </ul>
      </section>
    ))}
    <p id="empty-msg" class="service-empty">
      검색 결과가 없어요
    </p>
  </section>

  <p class="footnote">
    KRW 환산 기준 환율은 매일 갱신됩니다. 가격은 공식 가격 페이지 또는 공개 App Store 가격 데이터를 기준으로 합니다.
    구매 전 현지 결제 수단, 세금, 이용약관을 확인하세요.
  </p>
</Layout>

<script>
  const input = document.getElementById("svc-search") as HTMLInputElement;
  const countEl = document.getElementById("count") as HTMLElement;
  const emptyMsg = document.getElementById("empty-msg") as HTMLElement;
  const sections = [...document.querySelectorAll<HTMLElement>("[data-category-section]")];
  const items = [...document.querySelectorAll<HTMLElement>("li[data-search]")];

  function filterServices() {
    const q = input.value.trim().toLowerCase();
    let visible = 0;

    for (const li of items) {
      const match = !q || li.dataset.search!.includes(q);
      li.hidden = !match;
      if (match) visible++;
    }

    for (const section of sections) {
      const sectionItems = [...section.querySelectorAll<HTMLElement>("li[data-search]")];
      section.hidden = !sectionItems.some((li) => !li.hidden);
    }

    countEl.textContent = String(visible);
    emptyMsg.style.display = visible === 0 ? "block" : "none";
  }

  const initialQuery = new URLSearchParams(window.location.search).get("q");
  if (initialQuery) {
    input.value = initialQuery;
    filterServices();
  }

  input.addEventListener("input", filterServices);
</script>
